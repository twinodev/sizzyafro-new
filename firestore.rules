rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate: Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Checking if user is verified admin.
    // For safety, we can look up if their UID exists in of our /admins collection.
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 2. Rules for state management segments
    match /danceAppState/{segmentId} {
      // All segments (events, blogs, merchandise, partner logos) are readable by the public
      allow read: if true;

      // Allow write if request is from the server (unauthenticated request.auth == null),
      // or if the user is a registered admin,
      // or if no admins have been bootstrapped yet (to allow setting up the first admin).
      allow write: if request.auth == null || 
                      isAdmin() || 
                      (request.auth != null && !exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // admins table to track user roles
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // console-only to prevent self-promotion
    }
  }
}
